# Firebase Configuration
PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your_project_id
PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
PUBLIC_FIREBASE_APP_ID=your_app_id

# Convex
PUBLIC_CONVEX_URL=https://your_convex_deployment.convex.cloud

# App Settings
PUBLIC_APP_URL=https://collegecbt.ewinproject.org
PUBLIC_APP_NAME=CollegeCBT

# Resend Email
RESEND_API_KEY=your_resend_api_key

# Flutterwave Payments
PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-your_key
FLUTTERWAVE_SECRET_KEY=FLWSECK-your_secret

# KoraPay
PUBLIC_KORAPAY_PUBLIC_KEY=pk_your_korapay_key
KORAPAY_SECRET_KEY=sk_your_korapay_secret

# Seerbit
PUBLIC_SEERBIT_PUBLIC_KEY=your_seerbit_public_key
SEERBIT_SECRET_KEY=your_seerbit_secret

# Claude AI (Anthropic) - for server side
ANTHROPIC_API_KEY=your_anthropic_api_key

# Crawl4AI (Render deployment URL)
CRAWL4AI_API_URL=https://your-crawl4ai.onrender.com
CRAWL4AI_API_KEY=your_crawl4ai_key
