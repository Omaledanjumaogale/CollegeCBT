# ─────────────────────────────────────────────────────────────
# CollegeCBT — Environment Variables Reference
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env to version control.
# ─────────────────────────────────────────────────────────────

# ── FIREBASE AUTH (EwinProject Firebase Project) ──────────────
# Get these from Firebase Console → Project Settings → Your Apps
PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
PUBLIC_FIREBASE_APP_ID=1:your-sender-id:web:your-app-id
PUBLIC_FIREBASE_MEASUREMENT_ID=G-YOUR-MEASUREMENT-ID

# ── CONVEX BACKEND ────────────────────────────────────────────
# Get these from Convex Dashboard → Your Project → Settings
PUBLIC_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOYMENT=prod:your-project-name
CONVEX_DEPLOY_KEY=prod:your-project-name|your-deploy-key-here
CONVEX_HTTP_ACTIONS_URL=https://your-project.convex.site

# ── APP SETTINGS ──────────────────────────────────────────────
PUBLIC_APP_URL=https://collegecbt.ewinproject.org
PUBLIC_APP_NAME=CollegeCBT
PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ── RESEND EMAIL (Server-side only) ──────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key

# ── FLUTTERWAVE PAYMENTS ──────────────────────────────────────
# https://dashboard.flutterwave.com → API Keys
PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-your-public-key
FLUTTERWAVE_SECRET_KEY=FLWSECK-your-secret-key

# ── KORAPAY ───────────────────────────────────────────────────
# https://dashboard.korapay.com → Settings → API Keys
PUBLIC_KORAPAY_PUBLIC_KEY=pk_your-public-key
KORAPAY_SECRET_KEY=sk_your-secret-key

# ── CLAUDE AI (Anthropic) — Server side only ─────────────────
# https://console.anthropic.com → API Keys
# ⚠️  THIS KEY MUST NEVER be set as PUBLIC_ prefix
# ⚠️  Set as Cloudflare secret in production, NOT as plain env var
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ── CRAWL4AI (Optional AI browsing agent) ────────────────────
CRAWL4AI_API_URL=https://your-crawl4ai-instance.onrender.com
CRAWL4AI_API_KEY=your-crawl4ai-api-key

# ─────────────────────────────────────────────────────────────
# CLOUDFLARE PAGES DEPLOYMENT NOTES:
# 1. All PUBLIC_ vars → add in Cloudflare Pages → Settings → Environment Variables
# 2. ANTHROPIC_API_KEY → add as an ENCRYPTED SECRET in Cloudflare Pages
# 3. CONVEX_DEPLOY_KEY → also keep as an encrypted secret only
# ─────────────────────────────────────────────────────────────
